# Instagram / Meta App Credentials
INSTAGRAM_APP_ID=your_app_id_here
INSTAGRAM_APP_SECRET=your_app_secret_here

# Base URL of your app (for OAuth redirect)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Webhook verify token (any random string you choose)
WEBHOOK_VERIFY_TOKEN=your_random_verify_token

# Default URL to send in DMs
DEFAULT_REWARD_URL=https://omthakur.in
